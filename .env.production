NODE_ENV=production
PORT=5000

MONGO_URI=mongodb://mongo:27017/WDP

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

GITHUB_CLIENT_ID=change_me
GITHUB_CLIENT_SECRET=change_me
GITHUB_CALLBACK_URL=http://localhost:5000/api/github/oauth/callback
FRONTEND_URL=http://localhost:5000

LLM_PROVIDER=gemini
LLM_API_KEY=change_me
LLM_MODEL=gemini-1.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta




# chỉ gắn/example .env file
# Chỉ cần điền 3 chỗ chang me ở trên là có thể test được rồi nhé! 
# tự tạo gtihub OAuth App để lấy GITHUB client id và GTIHUB secret riêng. 
# gắn thêm API key của Gemini vào LLM_API_KEY để test nhé!