NODE_ENV=production
PORT=5000

MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority&appName=<app-name>
# Optional backward compatibility:
MONGODB_URI=

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_CLIENT_ID=change_me
GITHUB_CLIENT_SECRET=change_me
GITHUB_CALLBACK_URL=https://your-backend-url.onrender.com/api/github/oauth/callback
FRONTEND_URL=https://your-frontend-url.example.com
CLIENT_URL=https://your-frontend-url.example.com

LLM_PROVIDER=gemini
LLM_API_KEY=your_gemini_api_key
LLM_MODEL=gemini-2.0-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta

API_BASE_URL=https://your-backend-url.onrender.com
