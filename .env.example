NODE_ENV=production
PORT=5000

MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority&appName=<app-name>
# Optional backward compatibility:
MONGODB_URI=

JWT_SECRET=your_jwt_secret
GOOGLE_CLIENT_ID=970437677508-k1jc855q10hnl3sktcop9job68hgkd0r.apps.googleusercontent.com
JWT_EXPIRES_IN=7d

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_CLIENT_ID=change_me
GITHUB_CLIENT_SECRET=change_me
GITHUB_CALLBACK_URL=http://localhost:5000/api/github/oauth/callback
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:3000
FRONTEND_URLS=https://web-project-seven-rust.vercel.app,http://localhost:5173
MOBILE_REDIRECT_URL=gitanalyzer://github/connect
# Production example:
# GITHUB_CALLBACK_URL=https://career-roadmap-api-zs7y.onrender.com/api/github/oauth/callback
# FRONTEND_URL=https://web-project-seven-rust.vercel.app
# CLIENT_URL=https://web-project-seven-rust.vercel.app

LLM_PROVIDER=gemini
LLM_API_KEY=your_gemini_api_key
LLM_MODEL=gemini-2.5-flash
# LLM_MODEL should not include "models/". Use gemini-2.0-flash if gemini-2.5-flash is unavailable.
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta

API_BASE_URL=http://localhost:5000
